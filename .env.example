# Oracle Cloud Infrastructure (OCI) credentials
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- OCI API Config (content of ~/.oci/config) ---
OCI_CONFIG="[DEFAULT]
user=ocid1.user.oc1..xxxxxxxxxxxx
fingerprint=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99
tenancy=ocid1.tenancy.oc1..xxxxxxxxxxxx
region=eu-frankfurt-1
key_file=~/.oci/oci_api_key.pem"

# --- OCI API Private Key (content of your .pem file) ---
OCI_KEY="-----BEGIN RSA PRIVATE KEY-----
...your key here...
-----END RSA PRIVATE KEY-----"

# --- OCI Resource IDs ---
COMPARTMENT_ID=ocid1.compartment.oc1..xxxxxxxxxxxx

# --- For local testing with act (single region) ---
# Subnet of the region you want to test
SUBNET_ID=ocid1.subnet.oc1.eu-frankfurt-1.xxxxxxxxxxxx
# Region override (optional — leave empty to use OCI config default)
REGION=eu-frankfurt-1

# --- VM Shape Config (optional, defaults shown) ---
# MIN_OCPUS=2
# MAX_OCPUS=4
# MAX_MEMORY=19
# MIN_MEMORY=8
